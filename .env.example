# Anthropic API Key (for --provider claude)
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_key_here

# Google Gemini API Key (for --provider gemini)
# Get yours at https://aistudio.google.com/
GOOGLE_API_KEY=your_google_key_here

# OpenAI API Key (for --provider gpt)
# Get yours at https://platform.openai.com/
OPENAI_API_KEY=your_openai_key_here

# LLM-Forge Integration (optional)
# Enable auto-reporting of LLM calls to the central Hub
LLM_FORGE_ENABLED=true
LLM_FORGE_HUB_URL=http://localhost:8765
LLM_FORGE_PROJECT_ID=imggen
